<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0F0F"
    tools:context=".ThirdActivity">

    <TextView
        android:id="@+id/textViewThird"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="세 번째 화면"
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.1" />

    <LinearLayout
        android:id="@+id/buttonLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewThird"
        app:layout_constraintVertical_bias="0.3">

        <Button
            android:id="@+id/goMain3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="메인 화면으로" />

        <Button
            android:id="@+id/goSecond3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="두 번째 화면으로" />

        <Button
            android:id="@+id/goFourth3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="네 번째 화면으로" />

        <Button
            android:id="@+id/finish3rd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="종료"
            android:backgroundTint="#FF0000" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>